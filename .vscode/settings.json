{
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,
  "cmake.buildBeforeRun": true,
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
  "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.default.cppStandard": "c++26",
  "C_Cpp.default.compilerPath": "C:/Program Files/Microsoft Visual Studio/18/Community/VC/Tools/Llvm/x64/bin/clang-cl.exe",
  "C_Cpp.default.intelliSenseMode": "windows-clang-x64",
  "C_Cpp.errorSquiggles": "disabled",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--background-index"
  ],
  "clangd.fallbackFlags": [
    "-std=c++26",
    "-IC:/Users/dream/scoop/apps/vcpkg/current/installed/x64-windows/include"
  ],
  "clangd.enabled": false
}
